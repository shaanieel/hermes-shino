# Shino Hermes Agent — Environment Variables
# Copy this file to ~/.hermes/.env and fill in your values

# ============================================
# REQUIRED API KEYS
# ============================================

# OpenRouter / Router9 proxy key
OPENAI_API_KEY=sk-your-key-here

# Google Gemini (for vision/auxiliary)
GOOGLE_API_KEY=your-google-api-key

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_HOME_CHANNEL=8966896495
TELEGRAM_HOME_CHANNEL_NAME=BOSS SHOLEH

# ============================================
# GITHUB
# ============================================
GITHUB_TOKEN=ghp_your_github_token_here

# ============================================
# OPTIONAL
# ============================================
# COMMAND_CODE_API_KEY=your-key
# BROWSERBASE_API_KEY=your-key
